# .gitignore

# --- Logs ---
*.log
logs/
session_logs/
transcripts/

# --- Personal / PII ---
gemma_manifest.*
snapshot.json

# --- Credentials & Auth Caches ---
.cache
config/

# --- Device Registries (real data — templates only get committed) ---
devices.json

# --- Sensitive Policy Files (templates live in policies/, real configs do not) ---
HOME_ASSISTANT.md
WORKSPACE.md
INFRASTRUCTURE.md

# --- Memory & RAG (local only, never committed) ---
memory/

# --- Python Environment & Cache ---
gemma_stable_env/
__pycache__/
*.pyc
Python-3.11.15/

# --- RAG / Myne Jr build files (local only) ---
artoo_rag.py
build_db.py
ask_artoo.py
hailo/
spotify_api/

# --- Audio (recordings/scratch only — system sounds are tracked, see exception) ---
*.wav
!audio/*.wav

# --- Node / JS ---
node_modules/

# --- Workspace Extension ---
workspace-ext/

# --- Scratch / Temp ---
junk
old/
old.*
*.works
*.broke
*.bak

# --- Test files (specific exceptions preserved) ---
test_*
!test_artoo_tools.py
!test_gemma_tools.py
!test_spotify_control.py
!test_gemma_runtime.py

# --- Misc ---
hardware_probe.py
chroma_db/
