# --- v17.2.1 Gemma Live: Root-Level Tool Intercept Protocol ---
# Change Message (v17.2.1): 
# - Fixed receive_loop to intercept toolCall as a root WebSocket object instead of nested parts.
# - Implemented explicit console logging (🔧 TOOL CALL) to track exactly when Gemma signals Artoo.
# - Corrected client-to-server wire protocol to use camelCase (functionResponses) and pass mandatory tracking 'id'.
# - Updated setup structure to use strict camelCase (functionDeclarations) to ensure server schema acceptance.
import asyncio
import base64
import json
import os
import sys
import websockets
import threading
import time
import subprocess
import numpy as np
import sounddevice as sd
from openwakeword.model import Model

# --- 1. CONFIGURATION ---
API_KEY = os.environ.get("GEMINI_API_KEY")
MODEL = "gemini-3.1-flash-live-preview"
VOICE = "Aoede"

# Hardware / Audio Math
HW_FS = 48000
IN_RATIO = 3
OUT_RATIO = 2
MIC_BOOST = 8.0
OUT_BOOST = 1.2 

# Queues & Threading
input_queue = asyncio.Queue()
output_buffer = []
buffer_lock = threading.Lock()
is_gemma_outputting_sound = False 
last_activity_time = time.time()

# Wake Word
oww_model = Model(wakeword_models=["hey_mycroft"], inference_framework="onnx")

# --- 2. LOCAL TOOLS (Artoo Intercept) ---
def local_artoo_executor(command):
    cmd_lower = command.lower()
    
    # Spotify Control Routing
    if "album" in cmd_lower or "play" in cmd_lower:
        try:
            labs_dir = os.path.expanduser("~/google-labs")
            script_path = os.path.join(labs_dir, "spotify_control.py")
            clean_cmd = command.lower().replace("tell artoo", "").strip()
            
            spotify_env = os.environ.copy()
            spotify_env["SPOTIPY_CLIENT_ID"] = "9d6fbdf00c2c40abafa3949764ef2fe1"
            spotify_env["SPOTIPY_CLIENT_SECRET"] = "912d11c2ce22432ab78bcbb449bd0c9e"
            
            result = subprocess.check_output(
                [sys.executable, script_path, clean_cmd], 
                text=True, stderr=subprocess.STDOUT, cwd=labs_dir, env=spotify_env
            )
            return f"Artoo successfully handled the music request. Log: {result.strip()}"
        except Exception as e:
            return f"Spotify execution error: {str(e)}"
            
    # System Command Fallback
    else:
        try:
            result = subprocess.check_output(["gemini", "--model", MODEL, "--approval-mode", "yolo", command], text=True)
            return result
        except Exception as e:
            return f"Error contacting Artoo: {str(e)}"

# --- 3. AUDIO CALLBACKS ---
def mic_callback(indata, frames, time_info, status):
    if not is_gemma_outputting_sound:
        loop.call_soon_threadsafe(input_queue.put_nowait, indata.copy())

def spk_callback(outdata, frames, time_info, status):
    global output_buffer, is_gemma_outputting_sound
    with buffer_lock:
        if len(output_buffer) >= frames:
            chunk = np.array(output_buffer[:frames], dtype=np.float32)
            outdata[:, 0] = np.clip(chunk * OUT_BOOST, -1.0, 1.0)
            output_buffer = output_buffer[frames:]
            is_gemma_outputting_sound = np.max(np.abs(chunk)) > 0.01
        else:
            outdata.fill(0)
            is_gemma_outputting_sound = False 

# --- 4. THE LIVE BRAIN ---
async def start_gemini_session():
    global last_activity_time
    last_activity_time = time.time()
    uri = f"wss://generativelanguage.googleapis.com/ws/google.ai.generativelanguage.v1beta.GenerativeService.BidiGenerateContent?key={API_KEY}"
    
    try:
        async with websockets.connect(uri) as ws:
            setup = {
                "setup": {
                    "model": f"models/{MODEL}",
                    "generation_config": {"response_modalities": ["AUDIO"]},
                    "tools": [
                        {"functionDeclarations": [{
                            "name": "run_artoo_cmd", 
                            "description": "Run lab commands or control Spotify (e.g., 'album Abbey Road').", 
                            "parameters": {"type": "object", "properties": {"command": {"type": "string"}}, "required": ["command"]}
                        }]},
                        {"googleSearch": {}}
                    ]
                }
            }
            await ws.send(json.dumps(setup))
            await ws.recv()
            print("\n[LIVE] Session Active.")

            async def send_loop():
                while True:
                    indata = await input_queue.get()
                    audio_int16 = (np.clip(indata[::IN_RATIO] * MIC_BOOST, -1.0, 1.0) * 32767).astype(np.int16)
                    await ws.send(json.dumps({"realtime_input": {"audio": {"data": base64.b64encode(audio_int16.tobytes()).decode(), "mime_type": "audio/L16;rate=16000"}}}))

            async def receive_loop():
                async for message in ws:
                    msg = json.loads(message)
                    if "toolCall" in msg:
                        for fc in msg["toolCall"].get("functionCalls", []):
                            result = local_artoo_executor(fc["args"].get("command", ""))
                            await ws.send(json.dumps({"tool_response": {"functionResponses": [{"id": fc["id"], "response": {"result": result}}]}}))
                    
                    if "serverContent" in msg:
                        for part in msg["serverContent"].get("modelTurn", {}).get("parts", []):
                            if "inlineData" in part:
                                audio_fp32 = np.frombuffer(base64.b64decode(part["inlineData"]["data"]), dtype=np.int16).astype(np.float32) / 32767.0
                                with buffer_lock: output_buffer.extend(np.repeat(audio_fp32, OUT_RATIO).tolist())
                            elif "text" in part: print(f"\n[Gemma]: {part['text']}")
            
            await asyncio.gather(send_loop(), receive_loop())
    except Exception as e: print(f"\n[!] Session error: {e}")

async def main():
    global loop
    loop = asyncio.get_running_loop()
    with sd.InputStream(channels=1, samplerate=HW_FS, callback=mic_callback, blocksize=3840), \
         sd.OutputStream(channels=1, samplerate=HW_FS, callback=spk_callback, blocksize=1024):
        while True:
            indata = await input_queue.get()
            if oww_model.predict((indata[::IN_RATIO] * 32767).astype(np.int16).flatten())["hey_mycroft"] > 0.5:
                await start_gemini_session()

if __name__ == "__main__":
    try: asyncio.run(main())
    except KeyboardInterrupt: sys.exit(0)